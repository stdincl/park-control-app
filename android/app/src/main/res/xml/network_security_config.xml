<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext HTTP to local dev API (mirrors iOS NSExceptionDomains) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">local.parkcontrol.api.stdin.cl</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
